{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Docker: Start Services",
            "type": "shell",
            "command": "docker-compose",
            "args": ["up", "-d"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Docker: Stop Services",
            "type": "shell",
            "command": "docker-compose",
            "args": ["down"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Docker: View Logs",
            "type": "shell",
            "command": "docker-compose",
            "args": ["logs", "-f"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*",
                    "endsPattern": "^.*"
                }
            }
        },
        {
            "label": "Docker: Rebuild Services",
            "type": "shell",
            "command": "docker-compose",
            "args": ["up", "-d", "--build"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Docker: MySQL Shell",
            "type": "shell",
            "command": "docker-compose",
            "args": ["exec", "mysql", "mysql", "-uroot", "-ppassword", "-Dmyapp"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Docker: PHP Shell",
            "type": "shell",
            "command": "docker-compose",
            "args": ["exec", "php", "/bin/bash"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
